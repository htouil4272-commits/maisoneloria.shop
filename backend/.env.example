################################################################################
# Backend (FastAPI) — variables d'environnement EasyPanel
################################################################################

# --- Application ---
APP_NAME=Maison Eloria API
APP_VERSION=1.0.0
DEBUG=false

# --- Base de données ---
# Le hostname `maisoneloria_database` correspond au nom du service Postgres
# dans EasyPanel. Si vous l'avez nommé autrement, adaptez-le.
DATABASE_URL=postgresql+asyncpg://maisoneloria:CHANGE_ME@maisoneloria_database:5432/maisoneloria

# --- CORS ---
# Listez ici tous les domaines / sous-domaines qui appellent l'API.
# Séparés par des virgules, sans espace après la virgule.
ALLOWED_ORIGINS=https://maisoneloria.shop,https://www.maisoneloria.shop

# --- Auth admin (lecture du tableau de bord /admin) ---
# Le frontend envoie uniquement `password`. ADMIN_USERNAME reste pour la
# compat avec l'ancienne authentification HTTPBasic des outils internes.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Hamzatouil00@
# Secret aléatoire long (>=32 chars) pour signer les tokens d'admin.
# Si laissé vide, ADMIN_PASSWORD est utilisé comme fallback (déconseillé).
ADMIN_TOKEN_SECRET=

# --- Détection de fraude (optionnel) ---
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=data/GeoLite2-City.mmdb

# --- Google Sheets (optionnel) ---
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Conversions API (optionnel) ---
FB_ACCESS_TOKEN=
FB_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_PIXEL_ID=
SNAP_ACCESS_TOKEN=
SNAP_PIXEL_ID=

# --- Rate limiting ---
RATE_LIMIT_ORDERS_MAX=5
RATE_LIMIT_ORDERS_WINDOW=600
RATE_LIMIT_CONTACT_MAX=3
RATE_LIMIT_CONTACT_WINDOW=300
