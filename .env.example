# ============================================
# Maison Eloria — Environment Variables
# ============================================
# Copier ce fichier : cp .env.example .env
# Ne jamais committer le fichier .env dans Git.

# --- Admin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: n'utiliser QUE des caractères hex [0-9a-f] pour éviter tout problème Shell/Docker
ADMIN_TOKEN_SECRET=

# --- Database ---
# Format obligatoire pour SQLAlchemy/asyncpg :
DATABASE_URL=postgresql+asyncpg://maisoneloria:CHANGE_ME@maisoneloria_database:5432/maisoneloria

# --- Domains ---
NEXT_PUBLIC_API_URL=https://api.maisoneloria.shop
NEXT_PUBLIC_SITE_URL=https://maisoneloria.shop
ALLOWED_ORIGINS=https://maisoneloria.shop,https://www.maisoneloria.shop

# --- Facebook Pixel + CAPI ---
# Obtenir depuis : Facebook Events Manager → Data Sources → Votre Pixel
FB_PIXEL_ID=1544079200022148
FB_ACCESS_TOKEN=

# --- TikTok Pixel + CAPI ---
# Obtenir depuis : TikTok Ads Manager → Assets → Events
TIKTOK_PIXEL_ID=D80AC3RC77U9TECLM010
TIKTOK_ACCESS_TOKEN=

# --- Snapchat Pixel + CAPI ---
# Obtenir depuis : Snapchat Ads Manager → Events Manager
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

# --- MaxMind Fraud Protection ---
# Inscription gratuite : https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=

# --- Google Sheets ---
# 1. Créer un compte de service sur console.cloud.google.com
# 2. Activer l'API Google Sheets
# 3. Télécharger la clé JSON et la coller ci-dessous (une seule ligne)
# 4. Partager le spreadsheet avec l'e-mail du compte de service
GOOGLE_SHEETS_CREDENTIALS={}
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=212754127109
