  "faq": [
    {
      "q": { "fr": "Comment savoir quelle taille choisir ?", "ar": "كيف أعرف المقاس المناسب؟" },
      "a": {
        "fr": "Mesurez la largeur de l'assise de votre chaise. Standard : 45-50cm. Large : 50-55cm. XL : 55-60cm. En cas de doute, contactez-nous sur WhatsApp avec une photo de votre chaise et un mètre — nous vous conseillons gratuitement.",
        "ar": "قيسي عرض مقعد كرسيكِ. عادي: 45-50سم. كبير: 50-55سم. كبير جداً: 55-60سم. عند الشك، تواصلي معنا على واتساب مع صورة كرسيكِ ومتر — نحن ننصحكِ مجاناً."
      }
    },
    {
      "q": { "fr": "Comment laver les housses ?", "ar": "كيف أغسل الأغطية؟" },
      "a": {
        "fr": "À la machine, programme délicat 30°C. Séchage à l'air libre recommandé. Pas de sèche-linge ni de javel. Le tissu garde sa forme et ses couleurs après plus de 50 lavages.",
        "ar": "في الغسالة، برنامج ناعم 30°. يُفضّل التجفيف في الهواء الطلق. لا تستخدمي مجفف الملابس أو مبيض الكلور. القماش يحافظ على شكله وألوانه بعد أكثر من 50 غسلة."
      }
    },
    {
      "q": { "fr": "Combien de temps pour la livraison ?", "ar": "كم تستغرق مدة التوصيل؟" },
      "a": {
        "fr": "24 à 48 heures pour Casablanca, Rabat et Marrakech. 2 à 4 jours pour les autres villes du Maroc. Vous serez contacté(e) par WhatsApp pour confirmer votre commande sous 30 minutes.",
        "ar": "24 إلى 48 ساعة للدار البيضاء والرباط ومراكش. من 2 إلى 4 أيام لباقي مدن المغرب. سنتواصل معكِ عبر واتساب لتأكيد طلبكِ خلال 30 دقيقة."
      }
    },
    {
      "q": { "fr": "Comment payer ma commande ?", "ar": "كيف أدفع طلبي؟" },
      "a": {
        "fr": "Paiement à la livraison (COD) — vous ne payez qu'une fois votre colis reçu et vérifié. Aucune avance demandée. Espèces uniquement à la livraison.",
        "ar": "الدفع عند الاستلام — لا تدفعين إلا بعد استلام طردكِ والتحقق منه. لا حاجة لدفع أي شيء مقدماً. الدفع نقداً عند التسليم."
      }
    },
    {
      "q": { "fr": "Puis-je retourner ma commande ?", "ar": "هل يمكنني إرجاع الطلب؟" },
      "a": {
        "fr": "Oui — 14 jours pour changer d'avis. Si le produit ne vous plaît pas (taille, couleur, etc.), contactez-nous sur WhatsApp et nous échangerons ou rembourserons sans question.",
        "ar": "نعم — لديكِ 14 يوماً لتغيير رأيكِ. إذا لم يعجبكِ المنتج (المقاس، اللون، إلخ)، تواصلي معنا على واتساب وسنستبدل أو نسترجع المبلغ بدون أسئلة."
      }
    },
    {
      "q": { "fr": "Les housses sont-elles vraiment fabriquées au Maroc ?", "ar": "هل الأغطية مصنوعة فعلاً في المغرب؟" },
