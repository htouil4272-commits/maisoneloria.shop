################################################################################
# Frontend (Next.js) — variables d'environnement EasyPanel (build args)
################################################################################

# Laissez VIDE en production EasyPanel : le frontend appelle des chemins
# relatifs `/api/...` que nginx redirige vers le service backend interne.
# Si vous voulez forcer un domaine précis (ex: API hébergé séparément), mettez
# par ex `https://api.maisoneloria.shop`.
NEXT_PUBLIC_API_URL=

# Domaine public du site
NEXT_PUBLIC_SITE_URL=https://maisoneloria.shop


# Pixels publicitaires (laisser vide si non utilisés)
NEXT_PUBLIC_FB_PIXEL_ID=749884987768036
NEXT_PUBLIC_TT_PIXEL_ID=
NEXT_PUBLIC_SC_PIXEL_ID=
